{
  "name": "kairos",
  "version": "0.1.0",
  "description": "Kairos - local-first personal command center: CRM, tasks, objectives",
  "main": "./out/main/index.js",
  "author": "Santiago Coronado",
  "license": "MIT",
  "private": true,
  "scripts": {
    "dev": "electron-vite dev",
    "postinstall": "electron-rebuild -f -w better-sqlite3,node-pty && node scripts/patch-dev-electron-plist.js",
    "build": "electron-vite build && npm run build:mcp",
    "build:mcp": "tsup",
    "mcp:install": "npm run build:mcp && (claude mcp remove --scope user kairos >/dev/null 2>&1 || true) && claude mcp add --scope user kairos -- node \"$(pwd)/dist-mcp/index.mjs\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "helper:build": "bash scripts/build-calendar-helper.sh && bash scripts/build-contacts-helper.sh",
    "rebuild": "electron-rebuild -f -w better-sqlite3,node-pty",
    "dist": "npm run helper:build && electron-vite build && electron-builder --mac",
    "ship": "bash scripts/ship.sh"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.198",
    "@huggingface/transformers": "^4.2.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "baileys": "7.0.0-rc13",
    "better-sqlite3": "^12.11.1",
    "node-pty": "^1.1.0",
    "qrcode": "^1.5.4",
    "ulid": "^3.0.2",
    "umap-js": "^1.4.0",
    "web-push": "3.6.7",
    "ws": "8.21.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.1.0",
    "@tailwindcss/vite": "^4.3.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^26.1.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/web-push": "3.6.4",
    "@types/ws": "8.18.1",
    "@vitejs/plugin-react": "^5.2.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "cmdk": "^1.1.1",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
    "electron-vite": "^5.0.0",
    "lucide-react": "^1.23.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwindcss": "^4.3.2",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vite": "^7.3.6",
    "vitest": "^4.1.9"
  }
}
